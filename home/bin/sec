#!/bin/zsh

archive=~/Sed/sed.7z
dir=/tmp/sed

while getopts h opt; do
  case $opt in
    d) delete=1;;
    h) change=1;;
  esac
done
shift $[$OPTIND-1]

case $1 in
  e)
    [[ -d $dir ]] || { echo "$dir does not exist" >&2; exit 1; }
    echo 'Enter encryption password'
    while :; do
      read -rs 'pass?Password: '
      if [[ -f $archive ]] && ! 7z t -p"$pass" "$archive" &>/dev/null; then
        if [[ -n $change && -d $dir ]]; then
          echo Change password
        fi
        echo 'Incorrect password' >&2
        continue
      fi
      break
    done
    tmp=$(mktemp -u).7z
    if (cd "$dir" && 7z a -p"$pass" -mhe=on "$tmp" .) && mv "$tmp" "$archive"; then
      [[ -n $delete ]] && rm -r $dir
    fi
    :
    ;;
  d)
    [[ -d $dir ]] || mkdir $dir
    read -rs 'pass?Password: '
    7z x -p"$pass" -o"$dir" "$archive" && chmod 700 "$dir"
    ;;
  r)
    rm -r $dir
    ;;
  *)
    cat <<e
Usage: $(basename $0) COMMAND

Commands:
  e  encrypt
  d  decrypt
  r  remove
e
    ;;
esac
