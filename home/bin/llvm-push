#!/bin/zsh
setopt local_options no_case_match
branch=$(git branch --show-current)
if [[ $(git log -1 --pretty=%B) =~ 'WIP|DO NOT' ]]; then
  echo wip, dont push
  exit 1
fi

cd ~/llvm
git pull --rebase origin main || exit 1
LLVM_GITHUB_TOKEN=$(gh auth token) python llvm/utils/git-llvm-push --upstream-remote origin --remote maskray --auto-merge
#git push origin HEAD:main && git fetch origin main:main && git switch main || exit 1
#[[ $branch != main ]] && git branch -D $branch
